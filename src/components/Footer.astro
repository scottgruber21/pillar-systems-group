---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-navy text-brand-light/80 py-16 border-t border-brand-cyan/20">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12 border-b border-brand-gray/20 pb-12">
      
      <div class="md:col-span-2">
        <a href="/" class="flex flex-col mb-6 inline-block">
          <span class="font-heading font-extrabold text-3xl tracking-wider text-white leading-none">PILLAR</span>
          <span class="font-sans text-[10px] font-bold text-brand-cyan tracking-[0.2em] mt-1">SYSTEMS GROUP</span>
        </a>
        <p class="font-sans text-brand-light/70 leading-relaxed max-w-sm mb-6">
          Engineering high-performance digital platforms and measurable marketing systems for local businesses.
        </p>
      </div>

      <div>
        <h4 class="font-heading text-white font-bold mb-4 tracking-wide uppercase text-sm">Our Systems</h4>
        <nav class="flex flex-col gap-3 font-sans">
          <a href="/web-development" class="hover:text-brand-cyan transition-colors">Web Development</a>
          <a href="/seo" class="hover:text-brand-cyan transition-colors">Local SEO</a>
          <a href="/analytics" class="hover:text-brand-cyan transition-colors">Analytics & Tracking</a>
          </nav>
      </div>

      <div>
        <h4 class="font-heading text-white font-bold mb-4 tracking-wide uppercase text-sm">Contact</h4>
        <address class="font-sans not-italic flex flex-col gap-3">
          <p>
            <span class="block text-brand-light font-medium">Pillar Systems Group</span>
            Manville, NJ 08835
          </p>
          <a href="tel:+15551234567" class="hover:text-brand-cyan transition-colors flex items-center gap-2 mt-2">
            <svg class="w-4 h-4 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            (555) 123-4567
          </a>
          <a href="mailto:hello@pillarsystemsgroup.com" class="hover:text-brand-cyan transition-colors flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            Email Us
          </a>
        </address>
      </div>

    </div>

    <div class="flex flex-col md:flex-row justify-between items-center gap-4 font-sans text-sm text-brand-gray">
      <p>&copy; {currentYear} Pillar Systems Group. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy" class="hover:text-brand-light transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-brand-light transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>