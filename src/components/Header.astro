---
// src/components/Header.astro
---

<header class="bg-white border-b border-brand-gray/20 sticky top-0 z-50">
  <div class="container mx-auto px-4 py-4 flex justify-between items-center max-w-7xl relative z-20 bg-white">
    
    <a href="/" class="flex items-center">
      <img 
        src="/pillar-logo-main.png" 
        alt="Pillar Systems Group Logo" 
        class="h-20 md:h-24 w-auto object-contain transition-transform hover:scale-105 duration-300"
      />
    </a>

    <nav class="hidden md:flex gap-8 items-center font-sans font-medium text-brand-navy">
      <a href="/about" class="hover:text-brand-cyan transition-colors">About</a>
      <a href="/web-development" class="hover:text-brand-cyan transition-colors">Web Development</a>
      <a href="/seo" class="hover:text-brand-cyan transition-colors">SEO</a>
      <a href="/analytics" class="hover:text-brand-cyan transition-colors">Analytics</a>
      <a href="/contact" class="hover:text-brand-cyan transition-colors">Contact</a>
      <a href="/contact" class="bg-brand-cyan text-brand-navy px-6 py-2.5 rounded shadow-sm font-bold hover:bg-brand-navy hover:text-brand-cyan transition-all duration-300">
        Get a Site Audit
      </a>
    </nav>

    <button id="mobile-menu-btn" class="md:hidden text-brand-navy p-2 focus:outline-none" aria-label="Toggle Menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path id="menu-icon-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <nav id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-white border-b border-brand-gray/20 shadow-2xl flex-col font-sans font-medium text-brand-navy md:hidden z-10">
     <a href="/about" class="block px-6 py-4 border-b border-brand-gray/10 hover:bg-brand-light transition-colors">About</a>
    <a href="/web-development" class="block px-6 py-4 border-b border-brand-gray/10 hover:bg-brand-light transition-colors">Web Development</a>
    <a href="/seo" class="block px-6 py-4 border-b border-brand-gray/10 hover:bg-brand-light transition-colors">SEO</a>
    <a href="/analytics" class="block px-6 py-4 border-b border-brand-gray/10 hover:bg-brand-light transition-colors">Analytics</a>
    <a href="/contact" class="block px-6 py-4 border-b border-brand-gray/10 hover:bg-brand-light transition-colors">Contact</a>
    <div class="px-6 py-6 bg-brand-light/30">
      <a href="/contact" class="block text-center bg-brand-cyan text-brand-navy px-6 py-4 rounded shadow-sm font-bold hover:bg-brand-navy hover:text-brand-cyan transition-all text-lg">
        Get a Site Audit
      </a>
    </div>
  </nav>
</header>

<script>
  // Astro isolates and runs this vanilla JS automatically
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconPath = document.getElementById('menu-icon-path');

  btn?.addEventListener('click', () => {
    // Toggle the menu visibility
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
    
    // Animate the icon from a Hamburger to an 'X'
    if (menu?.classList.contains('hidden')) {
      iconPath?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    } else {
      iconPath?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    }
  });
</script>