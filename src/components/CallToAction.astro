---
// src/components/CallToAction.astro

// Define the properties this component accepts, with defaults
const { 
  headline = "Ready to stop losing leads to slower competitors?", 
  subheadline = "Get a comprehensive technical and local SEO audit of your current setup. No marketing fluff—just hard data and a blueprint for growth.",
  buttonText = "Claim Your Free Site Audit",
  buttonLink = "/contact"
} = Astro.props;
---

<section class="bg-brand-navy relative overflow-hidden py-24 border-t-4 border-brand-cyan mt-auto">
  <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
  
  <div class="container mx-auto px-4 text-center relative z-10 max-w-4xl">
    <h2 class="font-heading text-3xl md:text-5xl font-extrabold text-white mb-6 leading-tight">
      {headline}
    </h2>
    
    <p class="font-sans text-brand-light/80 text-lg md:text-xl mb-10 max-w-2xl mx-auto">
      {subheadline}
    </p>
    
    <a href={buttonLink} class="inline-block bg-brand-cyan text-brand-navy font-bold px-10 py-4 rounded text-lg shadow-[0_0_20px_rgba(0,209,255,0.3)] hover:shadow-[0_0_35px_rgba(0,209,255,0.6)] hover:-translate-y-1 transition-all duration-300">
      {buttonText}
    </a>
  </div>
</section>