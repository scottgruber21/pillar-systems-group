---
// src/components/CallToAction.astro

const { 
  headline = "Ready to stop losing leads to slower competitors?", 
  subheadline = "Get a comprehensive technical and local SEO audit of your current setup. No marketing fluff—just hard data and a blueprint for growth.",
  buttonText = "Claim Your Free Site Audit",
  buttonLink = "/contact"
} = Astro.props;
---

<section class="bg-brand-cyan relative overflow-hidden py-24 mt-auto">
  <div class="absolute inset-0 bg-grid-pattern opacity-5" style="--color-brand-cyan: var(--color-brand-navy);"></div>
  
  <div class="container mx-auto px-4 text-center relative z-10 max-w-4xl">
    
    <h2 class="font-heading text-3xl md:text-5xl font-extrabold text-brand-navy mb-6 leading-tight">
      {headline}
    </h2>
    
    <p class="font-sans text-brand-navy/80 text-lg md:text-xl mb-10 max-w-2xl mx-auto font-medium">
      {subheadline}
    </p>
    
    <a href={buttonLink} class="inline-block bg-brand-navy text-white font-bold px-10 py-4 rounded text-lg shadow-lg hover:shadow-2xl hover:-translate-y-1 hover:bg-white hover:text-brand-navy transition-all duration-300 border border-brand-navy/10">
      {buttonText}
    </a>
    
  </div>
</section>