---
// src/pages/analytics.astro
import BaseLayout from '../layouts/BaseLayout.astro';

// 1. Define the specific CTA for the Analytics page
const customCta = {
  headline: "Stop throwing marketing dollars into a black box.",
  subheadline: "Let's audit your current tracking setup and build a dashboard that actually proves your ROI.",
  buttonText: "Get an Analytics Audit",
  buttonLink: "/contact?service=analytics" 
};
---

<BaseLayout title="Data & Analytics Systems | Pillar Systems Group" cta={customCta}>
  
  <section class="bg-brand-navy pt-32 pb-20 relative overflow-hidden">
    <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-brand-cyan/10 blur-[100px] rounded-full"></div>
    
    <div class="container mx-auto px-4 max-w-4xl text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-cyan/10 border border-brand-cyan/20 text-brand-cyan font-bold text-sm uppercase tracking-wider mb-6">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
        Data & Tracking Systems
      </div>
      <h1 class="font-heading text-4xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
        Stop Guessing. <br/><span class="text-brand-cyan">Start Measuring.</span>
      </h1>
      <p class="font-sans text-xl text-brand-light/80 leading-relaxed max-w-2xl mx-auto text-balance">
        We turn raw data into a roadmap for your business so you know which campaigns are generating phone calls and which ones are burning cash.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white border-b border-brand-gray/10">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-heading text-3xl font-bold text-brand-navy mb-6">The "Vanity Metric" Trap</h2>
          <p class="font-sans text-brand-gray text-lg leading-relaxed mb-6">
            Traffic, impressions, and clicks look fantastic on a monthly report. But you cannot run payroll with pageviews. Most local businesses have no idea exactly where their best leads are actually coming from.
          </p>
          <ul class="space-y-4 font-sans text-brand-navy font-medium">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-red-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span>Paying for ads without tracking form submissions.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-red-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span>Getting phone calls but not knowing if they came from SEO or Facebook.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-red-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span>Relying on gut feeling instead of hard data.</span>
            </li>
          </ul>
        </div>
        
        <div class="bg-brand-navy p-8 rounded-2xl border border-brand-gray/20 shadow-xl relative">
           <div class="flex justify-between items-center mb-8 border-b border-white/10 pb-4">
             <h3 class="font-heading text-lg font-bold text-white">Lead Attribution</h3>
             <span class="text-brand-cyan text-sm font-bold border border-brand-cyan/30 bg-brand-cyan/10 px-3 py-1 rounded">Last 30 Days</span>
           </div>
           
           <div class="space-y-6">
             <div>
               <div class="flex justify-between text-sm text-brand-light/80 mb-2 font-medium">
                 <span>Organic Search (SEO)</span>
                 <span class="text-white font-bold">42 Leads</span>
               </div>
               <div class="w-full bg-white/5 rounded-full h-2.5">
                 <div class="bg-brand-cyan h-2.5 rounded-full" style="width: 75%"></div>
               </div>
             </div>
             <div>
               <div class="flex justify-between text-sm text-brand-light/80 mb-2 font-medium">
                 <span>Google Ads</span>
                 <span class="text-white font-bold">18 Leads</span>
               </div>
               <div class="w-full bg-white/5 rounded-full h-2.5">
                 <div class="bg-brand-cyan/70 h-2.5 rounded-full" style="width: 35%"></div>
               </div>
             </div>
             <div>
               <div class="flex justify-between text-sm text-brand-light/80 mb-2 font-medium">
                 <span>Direct / Referral</span>
                 <span class="text-white font-bold">8 Leads</span>
               </div>
               <div class="w-full bg-white/5 rounded-full h-2.5">
                 <div class="bg-brand-cyan/40 h-2.5 rounded-full" style="width: 15%"></div>
               </div>
             </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-brand-light">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="font-heading text-3xl lg:text-4xl font-bold text-brand-navy mb-4">Clean Data. Clear Decisions.</h2>
        <p class="font-sans text-brand-gray text-lg">We configure enterprise-grade tracking systems tailored specifically for local service businesses.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-xl shadow-sm border border-brand-gray/10 hover:border-brand-cyan transition-colors">
          <div class="w-12 h-12 bg-brand-navy/5 text-brand-cyan rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" /></svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-brand-navy mb-3">Conversion Mapping</h3>
          <p class="font-sans text-brand-gray leading-relaxed">
            We track the actions that actually matter. Form submissions, click-to-call buttons, and appointment bookings are wired directly into your analytics platform.
          </p>
        </div>

        <div class="bg-white p-8 rounded-xl shadow-sm border border-brand-gray/10 hover:border-brand-cyan transition-colors">
          <div class="w-12 h-12 bg-brand-navy/5 text-brand-cyan rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-brand-navy mb-3">Source Attribution</h3>
          <p class="font-sans text-brand-gray leading-relaxed">
            Stop guessing where your best clients come from. We set up UTM parameters and source tracking so you know if a lead originated from an organic search or a paid ad.
          </p>
        </div>

        <div class="bg-white p-8 rounded-xl shadow-sm border border-brand-gray/10 hover:border-brand-cyan transition-colors">
          <div class="w-12 h-12 bg-brand-navy/5 text-brand-cyan rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-brand-navy mb-3">Executive Reporting</h3>
          <p class="font-sans text-brand-gray leading-relaxed">
            No more drowning in complex spreadsheets. We build clean, automated dashboards that show you exactly what you need to know to make profitable business decisions.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>