---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="Pillar Systems Group | High-Performance Websites & Local SEO">
  
<section class="bg-brand-navy text-brand-light py-20 lg:py-32 relative overflow-hidden">
  
  <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
  
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] bg-brand-cyan/10 blur-[120px] rounded-full"></div>
  
  <div class="container mx-auto px-4 max-w-4xl text-center relative z-10">
    <h1 class="font-heading text-4xl lg:text-6xl font-extrabold leading-tight mb-6">
      The Foundation Your <span class="text-brand-cyan">Digital Presence</span> is Built On.
    </h1>
    <p class="font-sans text-lg lg:text-xl text-brand-light/80 mb-10 max-w-2xl mx-auto leading-relaxed text-balance">
      Stop losing customers to slow, bloated websites. We engineer high-performance platforms that rank locally, capture leads, and prove their ROI with clean analytics.
    </p>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="/contact" class="bg-brand-cyan text-brand-navy font-bold px-8 py-4 rounded shadow-lg hover:scale-105 transition-transform">
        Claim Your Free Site Audit
      </a>
      <a href="#services" class="border border-brand-cyan/30 text-brand-cyan font-bold px-8 py-4 rounded hover:bg-brand-cyan/5 transition-colors">
        Explore Our Approach
      </a>
    </div>
  </div>
</section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-3xl text-center">
      <h2 class="font-heading text-3xl font-bold text-brand-navy mb-6">Your current website is probably costing you money.</h2>
      <p class="font-sans text-brand-gray text-lg leading-relaxed">
        A beautiful digital brochure doesn't matter if it takes five seconds to load and ranks on page four of Google. Local search is highly competitive. If your site isn't technically optimized for speed and visibility, your competitors are getting the phone calls that should be yours.
      </p>
    </div>
  </section>

 <section id="services" class="py-24 bg-brand-light border-t border-brand-gray/10">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="font-heading text-3xl lg:text-4xl font-bold text-brand-navy mb-4">
        Built for Performance.<br/>Engineered for Growth.
      </h2>
      <p class="font-sans text-brand-gray">
        We focus strictly on the systems that generate measurable visibility and revenue.
      </p>
    </div>
    
    <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      
      <a href="/web-development" class="group bg-white p-10 rounded-2xl shadow-sm border border-brand-gray/10 hover:border-brand-cyan/50 hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 ease-out flex flex-col">
        <div class="h-14 w-14 bg-brand-navy text-brand-cyan rounded-xl flex items-center justify-center mb-8 group-hover:scale-110 group-hover:bg-brand-cyan group-hover:text-brand-navy transition-all duration-300">
          <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
          </svg>
        </div>
        <h3 class="font-heading text-2xl font-bold text-brand-navy mb-4 group-hover:text-brand-cyan transition-colors">High-Speed Architecture</h3>
        <p class="font-sans text-brand-gray mb-8 leading-relaxed flex-grow">
          We build lean, zero-bloat websites that load instantly. Faster load times mean better search rankings and frictionless user experiences.
        </p>
        <div class="flex items-center gap-2 font-bold text-brand-navy group-hover:gap-4 transition-all">
          <span>Explore Architecture</span>
          <svg class="w-5 h-5 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </div>
      </a>

      <a href="/seo" class="group bg-white p-10 rounded-2xl shadow-sm border border-brand-gray/10 hover:border-brand-cyan/50 hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 ease-out flex flex-col">
        <div class="h-14 w-14 bg-brand-navy text-brand-cyan rounded-xl flex items-center justify-center mb-8 group-hover:scale-110 group-hover:bg-brand-cyan group-hover:text-brand-navy transition-all duration-300">
          <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
          </svg>
        </div>
        <h3 class="font-heading text-2xl font-bold text-brand-navy mb-4 group-hover:text-brand-cyan transition-colors">Local SEO Targeting</h3>
        <p class="font-sans text-brand-gray mb-8 leading-relaxed flex-grow">
          Dominate your service area. We structure your site's content and metadata so search engines know exactly what you do and where you do it.
        </p>
        <div class="flex items-center gap-2 font-bold text-brand-navy group-hover:gap-4 transition-all">
          <span>View SEO Strategy</span>
          <svg class="w-5 h-5 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </div>
      </a>

      <a href="/analytics" class="group bg-white p-10 rounded-2xl shadow-sm border border-brand-gray/10 hover:border-brand-cyan/50 hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 ease-out flex flex-col">
        <div class="h-14 w-14 bg-brand-navy text-brand-cyan rounded-xl flex items-center justify-center mb-8 group-hover:scale-110 group-hover:bg-brand-cyan group-hover:text-brand-navy transition-all duration-300">
          <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V19.875c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125z" />
          </svg>
        </div>
        <h3 class="font-heading text-2xl font-bold text-brand-navy mb-4 group-hover:text-brand-cyan transition-colors">Clean Analytics</h3>
        <p class="font-sans text-brand-gray mb-8 leading-relaxed flex-grow">
          Stop guessing. We install rigorous tracking so you can see exactly how many leads your site is generating and prove your true ROI.
        </p>
        <div class="flex items-center gap-2 font-bold text-brand-navy group-hover:gap-4 transition-all">
          <span>View Analytics Hub</span>
          <svg class="w-5 h-5 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </div>
      </a>

    </div>
  </div>
</section>
</BaseLayout>