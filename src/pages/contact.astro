---
// src/pages/contact.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Request a Site Audit | Pillar Systems Group" hideCta={true}>
  
  <section class="bg-brand-navy pt-24 pb-12 relative overflow-hidden border-b border-brand-cyan/20">
    <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
    <div class="container mx-auto px-4 max-w-6xl relative z-10">
      <h1 class="font-heading text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-4">
        Let's audit your <span class="text-brand-cyan">Systems.</span>
      </h1>
      <p class="font-sans text-xl text-brand-light/80">
        No high-pressure sales. Just a technical review of your current digital footprint and a clear blueprint for growth.
      </p>
    </div>
  </section>

  <section class="py-20 bg-brand-light relative">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-20">
        
        <div class="lg:col-span-2 order-2 lg:order-1">
          <h2 class="font-heading text-2xl font-bold text-brand-navy mb-6">What happens next?</h2>
          
          <div class="space-y-8 mb-12">
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-cyan text-brand-navy font-bold flex items-center justify-center font-heading">1</div>
              <div>
                <h3 class="font-bold text-brand-navy mb-1">The Diagnostic Scan</h3>
                <p class="font-sans text-brand-gray text-sm leading-relaxed">We run your current website through rigorous performance and local SEO testing to identify exactly where you are leaking leads.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-cyan text-brand-navy font-bold flex items-center justify-center font-heading">2</div>
              <div>
                <h3 class="font-bold text-brand-navy mb-1">The Strategy Review</h3>
                <p class="font-sans text-brand-gray text-sm leading-relaxed">We schedule a brief, 15-minute call to review the hard data and show you what your competitors are doing right (and wrong).</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-cyan text-brand-navy font-bold flex items-center justify-center font-heading">3</div>
              <div>
                <h3 class="font-bold text-brand-navy mb-1">The Blueprint</h3>
                <p class="font-sans text-brand-gray text-sm leading-relaxed">You receive a clear, actionable proposal for building a high-speed revenue engine tailored to your exact service area.</p>
              </div>
            </div>
          </div>

          <div class="bg-white p-6 rounded-xl border border-brand-gray/10 shadow-sm">
            <h3 class="font-heading text-sm font-bold text-brand-navy uppercase tracking-wider mb-4">Direct Contact</h3>
            <address class="font-sans not-italic space-y-3 text-brand-gray">
              <p class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <span><strong>Pillar Systems Group</strong><br/>Manville, NJ 08835<br/>Serving Somerset County & Central NJ</span>
              </p>
              <p class="flex items-center gap-3">
                <svg class="w-5 h-5 text-brand-cyan shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                <a href="tel:+15551234567" class="hover:text-brand-cyan transition-colors">(555) 123-4567</a>
              </p>
              <p class="flex items-center gap-3">
                <svg class="w-5 h-5 text-brand-cyan shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                <a href="mailto:hello@pillarsystemsgroup.com" class="hover:text-brand-cyan transition-colors">hello@pillarsystemsgroup.com</a>
              </p>
            </address>
          </div>
        </div>

        <div class="lg:col-span-3 order-1 lg:order-2">
          <div class="bg-white p-8 lg:p-12 rounded-2xl shadow-xl border border-brand-gray/10">
            <form action="https://formspree.io/f/xpqkrdyd" method="POST" class="space-y-6 font-sans">
              
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-bold text-brand-navy mb-2">Full Name *</label>
                  <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded border border-brand-gray/30 focus:border-brand-cyan focus:ring-2 focus:ring-brand-cyan/20 outline-none transition-all text-brand-navy bg-brand-light/50 focus:bg-white" placeholder="John Doe">
                </div>
                <div>
                  <label for="company" class="block text-sm font-bold text-brand-navy mb-2">Business Name</label>
                  <input type="text" id="company" name="company" class="w-full px-4 py-3 rounded border border-brand-gray/30 focus:border-brand-cyan focus:ring-2 focus:ring-brand-cyan/20 outline-none transition-all text-brand-navy bg-brand-light/50 focus:bg-white" placeholder="Acme Plumbing">
                </div>
              </div>

              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="email" class="block text-sm font-bold text-brand-navy mb-2">Email Address *</label>
                  <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded border border-brand-gray/30 focus:border-brand-cyan focus:ring-2 focus:ring-brand-cyan/20 outline-none transition-all text-brand-navy bg-brand-light/50 focus:bg-white" placeholder="john@example.com">
                </div>
                <div>
                  <label for="phone" class="block text-sm font-bold text-brand-navy mb-2">Phone Number</label>
                  <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded border border-brand-gray/30 focus:border-brand-cyan focus:ring-2 focus:ring-brand-cyan/20 outline-none transition-all text-brand-navy bg-brand-light/50 focus:bg-white" placeholder="(555) 123-4567">
                </div>
              </div>

              <div>
                <label for="website" class="block text-sm font-bold text-brand-navy mb-2">Current Website URL</label>
                <input type="url" id="website" name="website" class="w-full px-4 py-3 rounded border border-brand-gray/30 focus:border-brand-cyan focus:ring-2 focus:ring-brand-cyan/20 outline-none transition-all text-brand-navy bg-brand-light/50 focus:bg-white" placeholder="https://www.yourwebsite.com">
                <p class="text-xs text-brand-gray mt-1">We'll run a preliminary speed and SEO scan on this domain.</p>
              </div>

              <div>
                <label for="service" class="block text-sm font-bold text-brand-navy mb-2">Primary Area of Interest</label>
                <select id="service" name="service" class="w-full px-4 py-3 rounded border border-brand-gray/30 focus:border-brand-cyan focus:ring-2 focus:ring-brand-cyan/20 outline-none transition-all text-brand-navy bg-brand-light/50 focus:bg-white appearance-none">
                  <option value="audit">Comprehensive Digital Audit</option>
                  <option value="web-dev">High-Speed Web Development</option>
                  <option value="seo">Local SEO & Visibility</option>
                  <option value="analytics">Analytics & Tracking Integration</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-bold text-brand-navy mb-2">Tell us about your current digital roadblocks.</label>
                <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded border border-brand-gray/30 focus:border-brand-cyan focus:ring-2 focus:ring-brand-cyan/20 outline-none transition-all text-brand-navy bg-brand-light/50 focus:bg-white resize-none" placeholder="Our current site is too slow, and we aren't showing up for local searches..."></textarea>
              </div>

              <button type="submit" class="w-full bg-brand-navy text-brand-cyan font-bold text-lg px-8 py-4 rounded shadow-lg hover:bg-brand-cyan hover:text-brand-navy hover:-translate-y-1 hover:shadow-xl transition-all duration-300">
                Request Technical Review
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>